# Database — use the same password in both variables
POSTGRES_PASSWORD=change-this-strong-db-password
DATABASE_URL=postgresql://postgres:change-this-strong-db-password@postgres:5432/trimvo

# Redis
REDIS_URL=redis://redis:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Cloudflare R2
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_PUBLIC_URL_TEMPLATES=https://pub-xxxx.r2.dev
R2_BUCKET_UPLOADS=uploads
R2_BUCKET_RESULTS=results
R2_BUCKET_TEMPLATES=templates

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200
REFRESH_TOKEN_EXPIRE_DAYS=30

# Stub settings (set false in production)
STUB_MODE=false
STUB_LATENCY_MS=10000
STUB_SUCCESS_RATE=0.8

# Replicate AI
REPLICATE_API_TOKEN=your_replicate_api_token_here

# Wavespeed.ai (akool/video-face-swap)
WAVESPEED_API_KEY=your_wavespeed_api_key_here

# Admin credentials (change in production!)
ADMIN_EMAIL=admin@trimvo.com
ADMIN_PASSWORD=change-this-strong-password

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Admin panel — URL of the API visible from the browser
VITE_API_URL=http://your-server-ip:8000/v1

# Apple In-App Purchase
# Bundle ID of your iOS app (e.g. com.yourcompany.trimvo)
APPLE_BUNDLE_ID=com.yourcompany.trimvo
# true = accept Sandbox receipts (dev/TestFlight), false = Production only
APPLE_SANDBOX=true
